<Window x:Class="SonnyTray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SonnyTray.ViewModels"
        xmlns:conv="clr-namespace:SonnyTray.Converters"
        xmlns:views="clr-namespace:SonnyTray.Views"
        xmlns:local="clr-namespace:SonnyTray"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        mc:Ignorable="d"
        Title="SonnyTray"
        Width="440" Height="740"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:ConnectionStateBrushConverter x:Key="StateBrush"/>
        <conv:BackendStateToTextConverter x:Key="StateText"/>
        <conv:OnlineStatusBrushConverter x:Key="OnlineBrush"/>
    </Window.Resources>

    <!-- Flyout shell -->
    <Border CornerRadius="8"
            Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource FlyoutStrokeBrush}"
            BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.35" Color="Black"/>
        </Border.Effect>

        <Grid>
            <!-- Loading overlay -->
            <Border Background="{DynamicResource BackgroundBrush}"
                    CornerRadius="8"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                    Panel.ZIndex="100">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE895;"
                               FontFamily="{DynamicResource IconFont}"
                               FontSize="28"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Connecting to Tailscale..."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Main content -->
            <DockPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">

                <!-- ── Profile bar ── -->
                <DockPanel DockPanel.Dock="Top">
                    <Button DockPanel.Dock="Right"
                            Style="{DynamicResource PopoutButton}"
                            Command="{Binding OpenAdminConsoleCommand}"
                            ToolTip="Open admin console"
                            Padding="10,10"
                            VerticalAlignment="Stretch">
                        <TextBlock Text="&#xE774;"
                                   FontFamily="{DynamicResource IconFont}"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button Style="{DynamicResource PopoutButton}"
                            Command="{Binding ProfileManager.ToggleProfilePickerCommand}"
                            Padding="14,10">
                        <DockPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Button}}"
                                   Margin="0,0,24,0">
                            <TextBlock DockPanel.Dock="Right"
                                       Text="&#xE70D;"
                                       FontFamily="{DynamicResource IconFont}"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"/>

                        <!-- Profile picture -->
                        <Border DockPanel.Dock="Left" CornerRadius="14" Width="28" Height="28"
                                Margin="0,0,10,0" VerticalAlignment="Center"
                                Background="{DynamicResource SurfaceBrush}">
                            <Border CornerRadius="14">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding ProfileManager.ProfilePicUrl}"
                                                Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ProfileManager.UserDisplayName}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="·" Margin="6,0"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TailnetName}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- Control server hostname -->
                            <TextBlock Text="{Binding ProfileManager.ControlHostName}"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}"
                                       FontSize="11"/>
                        </StackPanel>
                    </DockPanel>
                </Button>
                </DockPanel>

                <!-- ── Sticky Exit Node header ── -->
                <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource DividerBrush}"
                        x:Name="StickyExitNodeDivider" Visibility="Collapsed"/>
                <Button DockPanel.Dock="Top"
                        x:Name="StickyExitNodeHeader" Visibility="Collapsed"
                        Style="{DynamicResource PopoutButton}"
                        Command="{Binding ToggleExitNodePickerCommand}"
                        HorizontalContentAlignment="Stretch"
                        Padding="14,10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="&#xE70D;"
                                   FontFamily="{DynamicResource IconFont}" FontSize="10"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="180"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <StackPanel>
                            <TextBlock Text="Exit Node"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}" FontSize="11"/>
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="{Binding CurrentExitNodeFlag}"
                                                 FontSize="14" VerticalAlignment="Center"
                                                 Margin="0,0,6,0"
                                                 Visibility="{Binding HasExitNodeFlag, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding CurrentExitNodeName}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Button>

                <!-- ── Sticky Settings header ── -->
                <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource DividerBrush}"
                        x:Name="StickySettingsDivider" Visibility="Collapsed"/>
                <Button DockPanel.Dock="Top"
                        x:Name="StickySettingsHeader" Visibility="Collapsed"
                        Style="{DynamicResource PopoutButton}"
                        Command="{Binding ToggleSettingsCommand}"
                        HorizontalContentAlignment="Stretch"
                        Padding="14,10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="&#xE70D;"
                                   FontFamily="{DynamicResource IconFont}" FontSize="10"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="180"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;"
                                       FontFamily="{DynamicResource IconFont}" FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Settings"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                </Button>

                <!-- ── Scrollable content ── -->
                <ScrollViewer x:Name="ContentScroll" VerticalScrollBarVisibility="Auto"
                              ScrollChanged="OnContentScrollChanged">
                <StackPanel>

                <!-- ── Profile picker dropdown ── -->
                <Border Visibility="{Binding ProfileManager.ShowProfilePicker, Converter={StaticResource BoolToVis}}"
                        Background="Transparent"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="0,1"
                        Padding="4,4">
                    <StackPanel>
                        <!-- Add options view -->
                        <StackPanel Visibility="{Binding ProfileManager.ShowAddOptions, Converter={StaticResource BoolToVis}}"
                                    Margin="8">
                            <DockPanel Margin="0,0,0,8">
                                <Button DockPanel.Dock="Right"
                                        Content="&#xE711;"
                                        FontFamily="{DynamicResource IconFont}"
                                        FontSize="10"
                                        Style="{DynamicResource PopoutButton}"
                                        Command="{Binding ProfileManager.CancelAddServerCommand}"
                                        VerticalAlignment="Center"
                                        Padding="4,2"/>
                                <TextBlock Text="Add account"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontWeight="SemiBold" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <!-- Add Tailscale account button -->
                            <Button Style="{DynamicResource PopoutButton}"
                                    Command="{Binding ProfileManager.AddTailscaleAccountCommand}"
                                    Padding="10,8" Margin="0,0,0,4"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8FA;"
                                               FontFamily="{DynamicResource IconFont}"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Tailscale account"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontFamily="{DynamicResource BodyFont}"
                                                   FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="Sign in with a different account or tailnet"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   FontFamily="{DynamicResource BodyFont}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <!-- Custom server (Headscale) expandable section -->
                            <Button Style="{DynamicResource PopoutButton}"
                                    Command="{Binding ProfileManager.ShowCustomServerInputCommand}"
                                    Padding="10,8" Margin="0,0,0,4"
                                    HorizontalContentAlignment="Left"
                                    Visibility="{Binding ProfileManager.ShowAddCustomServer, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE968;"
                                               FontFamily="{DynamicResource IconFont}"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Other server"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontFamily="{DynamicResource BodyFont}"
                                                   FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="Headscale or custom control server"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   FontFamily="{DynamicResource BodyFont}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <!-- Custom server URL input (shown when expanded) -->
                            <StackPanel Visibility="{Binding ProfileManager.ShowAddCustomServer, Converter={StaticResource BoolToVis}}"
                                        Margin="0,4,0,0">
                                <TextBlock Text="Server URL"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="11" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding ProfileManager.NewServerUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource InputTextBox}"
                                         Tag="https://headscale.example.com"
                                         Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Cancel"
                                            Style="{DynamicResource PopoutButton}"
                                            Command="{Binding ProfileManager.CancelAddServerCommand}"
                                            Margin="0,0,4,0"/>
                                    <Button Content="Connect"
                                            Style="{DynamicResource AccentButton}"
                                            Command="{Binding ProfileManager.AddCustomServerCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Profile list -->
                        <ItemsControl ItemsSource="{Binding ProfileManager.Profiles}"
                                      Visibility="{Binding ProfileManager.ShowAddOptions, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{DynamicResource PopoutButton}"
                                            Command="{Binding DataContext.ProfileManager.SwitchProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Id}"
                                            Padding="10,6">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="&#xE73E;"
                                                       FontFamily="{DynamicResource IconFont}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0"
                                                       Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontFamily="{DynamicResource BodyFont}" FontSize="12">
                                                    <Run Text="{Binding UserName, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                    <Run Text="·" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                    <Run Text="{Binding ServerHostName, Mode=OneWay}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding TailnetDisplayName}"
                                                           FontFamily="{DynamicResource BodyFont}" FontSize="11"
                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                           Visibility="{Binding HasTailnetDisplayName, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="＋  Add account..."
                                Style="{DynamicResource PopoutButton}"
                                Command="{Binding ProfileManager.ShowAddServerViewCommand}"
                                Foreground="{DynamicResource AccentBrush}"
                                FontSize="12"
                                Visibility="{Binding ProfileManager.ShowAddOptions, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                    </StackPanel>
                </Border>

                <!-- Divider -->
                <Border Height="1" Background="{DynamicResource DividerBrush}"/>

                <!-- ── Connection section ── -->
                <Border Padding="14,12,14,10">
                    <DockPanel>
                        <!-- Toggle switch on the right -->
                        <local:FluentToggleButton DockPanel.Dock="Right"
                                      Style="{DynamicResource FluentToggle}"
                                      IsChecked="{Binding IsConnected, Mode=OneWay}"
                                      Command="{Binding ToggleConnectionCommand}"
                                      IsEnabled="{Binding IsNotBusy}"
                                      VerticalAlignment="Top"
                                      Margin="12,2,0,0"
                                      Visibility="{Binding NeedsLogin, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>

                        <StackPanel>
                            <!-- Status line -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                         Fill="{Binding BackendState, Converter={StaticResource StateBrush}}"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding BackendState, Converter={StaticResource StateText}}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontWeight="SemiBold" FontSize="14"/>
                            </StackPanel>

                            <!-- Needs login prompt -->
                            <StackPanel Visibility="{Binding NeedsLogin, Converter={StaticResource BoolToVis}}"
                                        Margin="0,2,0,0">
                                <TextBlock Text="Sign in to connect this device to your tailnet."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="12" TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <Button Content="Log in"
                                        Style="{DynamicResource AccentButton}"
                                        Command="{Binding LoginCommand}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>

                            <!-- Connected info -->
                            <StackPanel Visibility="{Binding NeedsLogin, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="12"
                                           Text="{Binding SelfHostName}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding SelfIP}"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               FontFamily="{DynamicResource BodyFont}"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <Button Style="{DynamicResource PopoutButton}"
                                            Command="{Binding ToggleCopyMenuCommand}"
                                            Padding="4,2" Margin="2,0,0,0"
                                            ToolTip="Copy to clipboard">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8C8;"
                                                       FontFamily="{DynamicResource IconFont}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock FontFamily="{DynamicResource IconFont}"
                                                       FontSize="8"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="3,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#xE70D;"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowCopyMenu}" Value="True">
                                                                <Setter Property="Text" Value="&#xE70E;"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <!-- Expanded copy options (inline, no border) -->
                                <StackPanel Visibility="{Binding ShowCopyMenu, Converter={StaticResource BoolToVis}}"
                                            Margin="0,4,0,0">
                                    <Button Style="{DynamicResource PopoutButton}"
                                            Command="{Binding CopyToClipboardCommand}"
                                            CommandParameter="{Binding SelfIP}"
                                            Padding="6,4" HorizontalContentAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8C8;"
                                                       FontFamily="{DynamicResource IconFont}"
                                                       FontSize="10" Margin="0,0,8,0"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock FontFamily="{DynamicResource BodyFont}" FontSize="12" VerticalAlignment="Center">
                                                <Run Text="IPv4" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding SelfIP, Mode=OneWay}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{DynamicResource PopoutButton}"
                                            Command="{Binding CopyToClipboardCommand}"
                                            CommandParameter="{Binding SelfIPv6}"
                                            Padding="6,4" HorizontalContentAlignment="Left"
                                            Visibility="{Binding SelfIPv6, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8C8;"
                                                       FontFamily="{DynamicResource IconFont}"
                                                       FontSize="10" Margin="0,0,8,0"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock FontFamily="{DynamicResource BodyFont}" FontSize="12" VerticalAlignment="Center"
                                                       MaxWidth="260" TextTrimming="CharacterEllipsis">
                                                <Run Text="IPv6" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding SelfIPv6, Mode=OneWay}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{DynamicResource PopoutButton}"
                                            Command="{Binding CopyToClipboardCommand}"
                                            CommandParameter="{Binding SelfDNSName}"
                                            Padding="6,4" HorizontalContentAlignment="Left"
                                            Visibility="{Binding SelfDNSName, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8C8;"
                                                       FontFamily="{DynamicResource IconFont}"
                                                       FontSize="10" Margin="0,0,8,0"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock FontFamily="{DynamicResource BodyFont}" FontSize="12" VerticalAlignment="Center"
                                                       MaxWidth="260" TextTrimming="CharacterEllipsis">
                                                <Run Text="DNS" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding SelfDNSName, Mode=OneWay}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{DynamicResource PopoutButton}"
                                            Command="{Binding CopyToClipboardCommand}"
                                            CommandParameter="{Binding SelfHostName}"
                                            Padding="6,4" HorizontalContentAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8C8;"
                                                       FontFamily="{DynamicResource IconFont}"
                                                       FontSize="10" Margin="0,0,8,0"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock FontFamily="{DynamicResource BodyFont}" FontSize="12" VerticalAlignment="Center">
                                                <Run Text="Host" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding SelfHostName, Mode=OneWay}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <!-- Logout link -->
                                <Button Style="{DynamicResource PopoutButton}"
                                        Command="{Binding LogoutCommand}"
                                        Padding="0,4,0,0"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="Log out"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               FontFamily="{DynamicResource BodyFont}"
                                               FontSize="11"
                                               TextDecorations="Underline"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Divider -->
                <Border Height="1" Background="{DynamicResource DividerBrush}"/>

                <!-- ── Exit node row ── -->
                <Button x:Name="ExitNodeHeader"
                        Style="{DynamicResource PopoutButton}"
                        Command="{Binding ToggleExitNodePickerCommand}"
                        HorizontalContentAlignment="Stretch"
                        Padding="14,10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="&#xE70D;"
                                   FontFamily="{DynamicResource IconFont}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="ExitNodeChevronRotate" Angle="0"/>
                            </TextBlock.RenderTransform>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowExitNodePicker}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                         To="180" Duration="0:0:0.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                         To="0" Duration="0:0:0.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel>
                            <TextBlock Text="Exit Node"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}"
                                       FontSize="11"/>
                            <StackPanel Orientation="Horizontal">
                                <emoji:TextBlock Text="{Binding CurrentExitNodeFlag}"
                                                 FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,6,0"
                                                 Visibility="{Binding HasExitNodeFlag, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding CurrentExitNodeName}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontFamily="{DynamicResource BodyFont}"
                                           FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Button>

                <!-- Exit Node Picker (inline) -->
                <views:ExitNodePicker DataContext="{Binding ExitNodePicker}"
                                      Visibility="{Binding DataContext.ShowExitNodePicker, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>

                <!-- Divider -->
                <Border Height="1" Background="{DynamicResource DividerBrush}"/>

                <!-- ── Settings row ── -->
                <Button x:Name="SettingsHeader"
                        Style="{DynamicResource PopoutButton}"
                        Command="{Binding ToggleSettingsCommand}"
                        HorizontalContentAlignment="Stretch"
                        Padding="14,10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="&#xE70D;"
                                   FontFamily="{DynamicResource IconFont}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="SettingsChevronRotate" Angle="0"/>
                            </TextBlock.RenderTransform>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowSettings}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                         To="180" Duration="0:0:0.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                         To="0" Duration="0:0:0.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;"
                                       FontFamily="{DynamicResource IconFont}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="Settings"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                </Button>

                <!-- ── Settings panel (inline) ── -->
                <Border Visibility="{Binding ShowSettings, Converter={StaticResource BoolToVis}}"
                        Background="Transparent"
                        BorderBrush="{DynamicResource CardStrokeBrush}"
                        BorderThickness="0,1"
                        Padding="6,6">
                    <StackPanel>
                        <!-- Allow incoming connections (inverted ShieldsUp) -->
                        <DockPanel Margin="8,4">
                            <local:FluentToggleButton DockPanel.Dock="Right"
                                          Style="{DynamicResource FluentToggle}"
                                          IsChecked="{Binding Settings.AllowIncomingConnections}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Allow incoming connections"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Use Tailscale DNS -->
                        <DockPanel Margin="8,4">
                            <local:FluentToggleButton DockPanel.Dock="Right"
                                          Style="{DynamicResource FluentToggle}"
                                          IsChecked="{Binding Settings.UseTailscaleDns}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Use Tailscale DNS settings"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Use Tailscale subnets -->
                        <DockPanel Margin="8,4">
                            <local:FluentToggleButton DockPanel.Dock="Right"
                                          Style="{DynamicResource FluentToggle}"
                                          IsChecked="{Binding Settings.UseTailscaleSubnets}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Use Tailscale subnets"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Allow local network access -->
                        <DockPanel Margin="8,4">
                            <local:FluentToggleButton DockPanel.Dock="Right"
                                          Style="{DynamicResource FluentToggle}"
                                          IsChecked="{Binding Settings.AllowLANAccess}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Allow LAN access"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Auto update -->
                        <DockPanel Margin="8,4">
                            <local:FluentToggleButton DockPanel.Dock="Right"
                                          Style="{DynamicResource FluentToggle}"
                                          IsChecked="{Binding Settings.AutoUpdate}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Automatically install updates"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Run unattended -->
                        <DockPanel Margin="8,4">
                            <local:FluentToggleButton DockPanel.Dock="Right"
                                          Style="{DynamicResource FluentToggle}"
                                          IsChecked="{Binding Settings.RunUnattended}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Run unattended"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Run at startup -->
                        <DockPanel Margin="8,4">
                            <local:FluentToggleButton DockPanel.Dock="Right"
                                          Style="{DynamicResource FluentToggle}"
                                          IsChecked="{Binding Settings.RunAtStartup}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Run at startup"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- TailDrive section -->
                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="4,6"/>
                        <StackPanel>
                            <DockPanel Margin="8,4">
                                <Button DockPanel.Dock="Right"
                                        Content="&#xE710;"
                                        FontFamily="{DynamicResource IconFont}"
                                        FontSize="12"
                                        Command="{Binding Settings.ShowAddShareViewCommand}"
                                        ToolTip="Share a folder"
                                        VerticalAlignment="Center"
                                        Padding="6,2">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PopoutButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Settings.DriveError}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8B7;"
                                               FontFamily="{DynamicResource IconFont}"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Taildrive"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Settings.IsTailDriveMounted}" Value="True">
                                                        <Setter Property="Text" Value="{Binding Settings.TailDriveLetter, StringFormat='Taildrive ({0}:)'}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>

                            <!-- Add share form -->
                            <StackPanel Visibility="{Binding Settings.ShowAddShare, Converter={StaticResource BoolToVis}}"
                                        Margin="8,4,8,8">
                                <TextBlock Text="Share name"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="{DynamicResource BodyFont}" FontSize="11"
                                           Margin="0,0,0,2"/>
                                <TextBox Text="{Binding Settings.NewShareName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource InputTextBox}"
                                         Tag="e.g. Documents"
                                         Margin="0,0,0,6"/>
                                <TextBlock Text="Folder"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="{DynamicResource BodyFont}" FontSize="11"
                                           Margin="0,0,0,2"/>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right"
                                            Content="Browse..."
                                            Style="{DynamicResource PopoutButton}"
                                            Command="{Binding Settings.BrowseShareFolderCommand}"
                                            Padding="8,4" Margin="4,0,0,0"
                                            FontSize="11"
                                            VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding Settings.NewSharePath, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource InputTextBox}"
                                             Tag="C:\Users\you\folder"/>
                                </DockPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Cancel"
                                            Style="{DynamicResource PopoutButton}"
                                            Command="{Binding Settings.CancelAddShareCommand}"
                                            Margin="0,0,4,0"/>
                                    <Button Content="Share"
                                            Style="{DynamicResource AccentButton}"
                                            Command="{Binding Settings.AddShareCommand}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Shares list -->
                            <ItemsControl ItemsSource="{Binding Settings.DriveShares}"
                                          Margin="8,0,8,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,2">
                                            <Button DockPanel.Dock="Right"
                                                    Content="&#xE711;"
                                                    FontFamily="{StaticResource IconFont}"
                                                    FontSize="10"
                                                    Style="{DynamicResource PopoutButton}"
                                                    Command="{Binding DataContext.Settings.RemoveShareCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Name}"
                                                    ToolTip="Remove share"
                                                    Padding="4,2"
                                                    VerticalAlignment="Center"/>
                                            <Button DockPanel.Dock="Right"
                                                    Content="&#xE838;"
                                                    FontFamily="{StaticResource IconFont}"
                                                    FontSize="10"
                                                    Style="{DynamicResource PopoutButton}"
                                                    Command="{Binding DataContext.Settings.OpenShareFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Path}"
                                                    ToolTip="Open folder"
                                                    Padding="4,2"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,2,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontFamily="{DynamicResource BodyFont}" FontSize="12"/>
                                                <TextBlock Text="{Binding Path}"
                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                           FontFamily="{DynamicResource BodyFont}" FontSize="10"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty state: no shares -->
                            <TextBlock Text="No shared folders"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}" FontSize="11"
                                       Margin="8,2,8,4"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Settings.DriveShares.Count}" Value="0"/>
                                                    <Condition Binding="{Binding Settings.DriveError}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- Empty state: Taildrive not available -->
                            <TextBlock Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}" FontSize="11"
                                       Margin="8,2,8,4"
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding Settings.DriveError, Converter={StaticResource BoolToVis}}">
                                <Run Text="Taildrive not available."/>
                                <Hyperlink NavigateUri="https://tailscale.com/kb/1369/taildrive"
                                           RequestNavigate="OnHyperlinkRequestNavigate"
                                           Foreground="{DynamicResource AccentBrush}">Learn more</Hyperlink>
                            </TextBlock>

                            <!-- Mount / Unmount Taildrive -->
                            <!-- Mounted state: prominent card -->
                            <Border Margin="8,4"
                                    Background="{DynamicResource ControlBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,8"
                                    Visibility="{Binding Settings.IsTailDriveMounted, Converter={StaticResource BoolToVis}}">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="&#xE838;"
                                                FontFamily="{DynamicResource IconFont}"
                                                FontSize="12"
                                                Style="{DynamicResource PopoutButton}"
                                                Command="{Binding Settings.OpenTailDriveCommand}"
                                                Padding="6,4"
                                                VerticalAlignment="Center"
                                                Margin="0,0,2,0"/>
                                        <Button Content="Unmount"
                                                FontFamily="{DynamicResource BodyFont}"
                                                FontSize="11"
                                                Style="{DynamicResource PopoutButton}"
                                                Command="{Binding Settings.UnmountTailDriveCommand}"
                                                Padding="8,4"
                                                VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Settings.TailDriveLetter, StringFormat='{}{0}:'}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontFamily="{DynamicResource BodyFont}" FontSize="13"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="http://100.100.100.100:8080/"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   FontFamily="{DynamicResource BodyFont}" FontSize="10"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <!-- Not mounted: mount button -->
                            <DockPanel Margin="8,2">
                                <Button DockPanel.Dock="Right"
                                        Content="Mount"
                                        FontFamily="{DynamicResource BodyFont}"
                                        FontSize="11"
                                        Command="{Binding Settings.ShowMountDriveViewCommand}"
                                        ToolTip="Mount Taildrive as a drive letter"
                                        VerticalAlignment="Center"
                                        Padding="8,2">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PopoutButton}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Settings.IsTailDriveMounted}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Settings.ShowMountDrive}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <TextBlock Foreground="{DynamicResource TextTertiaryBrush}"
                                           FontFamily="{DynamicResource BodyFont}" FontSize="11"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Not mounted"/>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Settings.IsTailDriveMounted}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DockPanel>

                            <!-- Mount drive form (drive letter + buttons on one line) -->
                            <DockPanel Visibility="{Binding Settings.ShowMountDrive, Converter={StaticResource BoolToVis}}"
                                       Margin="8,4,8,8">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Cancel"
                                            Style="{DynamicResource PopoutButton}"
                                            Command="{Binding Settings.CancelMountDriveCommand}"
                                            Padding="8,4"
                                            Margin="4,0,4,0"/>
                                    <Button Content="Mount"
                                            Style="{DynamicResource AccentButton}"
                                            Command="{Binding Settings.MountDriveCommand}"
                                            Padding="10,4"/>
                                </StackPanel>
                                <ComboBox Style="{DynamicResource InputComboBox}"
                                          ItemsSource="{Binding Settings.AvailableDriveLetters}"
                                          SelectedItem="{Binding Settings.MountDriveLetter}"
                                          FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                          VerticalAlignment="Center"/>
                            </DockPanel>

                            <!-- WebDAV file size limit patch -->
                            <DockPanel Margin="8,4">
                                <Button DockPanel.Dock="Right"
                                        Content="Patch"
                                        FontFamily="{DynamicResource BodyFont}"
                                        FontSize="11"
                                        Command="{Binding Settings.PatchFileSizeLimitCommand}"
                                        VerticalAlignment="Center"
                                        Padding="8,2">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PopoutButton}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Settings.IsFileSizePatched}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontFamily="{DynamicResource BodyFont}" FontSize="11"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                <Setter Property="Text" Value="WebDAV file limit: 50 MB (default)"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Settings.IsFileSizePatched}" Value="True">
                                                        <Setter Property="Text" Value="WebDAV file limit: 4 GB &#x2713;"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="4,6"/>

                        <!-- Theme selector -->
                        <DockPanel Margin="8,4">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="System"
                                        Style="{DynamicResource PopoutButton}"
                                        Padding="8,4" FontSize="11"
                                        Click="OnThemeSystemClick"/>
                                <Button Content="Dark"
                                        Style="{DynamicResource PopoutButton}"
                                        Padding="8,4" FontSize="11"
                                        Click="OnThemeDarkClick"/>
                                <Button Content="Light"
                                        Style="{DynamicResource PopoutButton}"
                                        Padding="8,4" FontSize="11"
                                        Click="OnThemeLightClick"/>
                            </StackPanel>
                            <TextBlock Text="Theme"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="4,6"/>

                        <!-- Reset to defaults -->
                        <Button Content="Reset to defaults"
                                Style="{DynamicResource PopoutButton}"
                                Command="{Binding Settings.ResetToDefaultsCommand}"
                                Foreground="{DynamicResource TextTertiaryBrush}"
                                FontSize="12" Padding="8,6"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Divider -->
                <Border Height="1" Background="{DynamicResource DividerBrush}"/>

                <!-- ── Peer Detail (replaces list when shown) ── -->
                <views:PeerDetail
                                  DataContext="{Binding PeerDetail}"
                                  Visibility="{Binding DataContext.ShowPeerDetail, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>

                <!-- ── Peer list ── -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowPeerDetail}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <StackPanel Orientation="Horizontal" Margin="14,8,14,4">
                        <TextBlock Text="DEVICES"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   FontFamily="{DynamicResource BodyFont}"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding Peers}" Padding="4,0,4,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,7" CornerRadius="4" Cursor="Hand"
                                            MouseLeftButtonUp="OnPeerClick">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SubtleBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <DockPanel>
                                            <Ellipse DockPanel.Dock="Left"
                                                     Width="8" Height="8"
                                                     Fill="{Binding IsOnline, Converter={StaticResource OnlineBrush}}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,10,0"/>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding IP}"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       FontFamily="{DynamicResource BodyFont}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontFamily="{DynamicResource BodyFont}"
                                                           FontSize="13"/>
                                                <TextBlock Text="{Binding OS}"
                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                           FontFamily="{DynamicResource BodyFont}"
                                                           FontSize="11"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                </StackPanel>

                </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </Border>
</Window>
