<UserControl x:Class="SonnyTray.Views.ExitNodePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
             xmlns:vm="clr-namespace:SonnyTray.ViewModels"
             xmlns:conv="clr-namespace:SonnyTray.Converters"
             xmlns:local="clr-namespace:SonnyTray"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ExitNodePickerViewModel}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:OnlineStatusBrushConverter x:Key="OnlineBrush"/>
    </UserControl.Resources>

    <Border Background="Transparent"
            BorderBrush="{DynamicResource CardStrokeBrush}"
            BorderThickness="0,1"
            Padding="6,6">
        <DockPanel>
            <!-- Search bar -->
            <TextBox DockPanel.Dock="Top"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Style="{DynamicResource SearchTextBox}"
                     Margin="4,2,4,8"/>

            <!-- Loading indicator -->
            <TextBlock DockPanel.Dock="Top"
                       Text="Loading exit nodes..."
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       FontFamily="{DynamicResource BodyFont}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,24,0,24"
                       Visibility="{Binding IsLoadingNodes, Converter={StaticResource BoolToVis}}"/>

            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoadingNodes}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                    <DockPanel Margin="12,6,12,2">
                        <local:FluentToggleButton DockPanel.Dock="Right"
                                      Style="{DynamicResource FluentToggle}"
                                      IsChecked="{Binding DataContext.Settings.AdvertiseExitNode, RelativeSource={RelativeSource AncestorType=Window}}"
                                      VerticalAlignment="Center"/>
                        <TextBlock Text="Run exit node"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="4,6"/>

                    <!-- Suggested exit node -->
                    <StackPanel Visibility="{Binding SuggestedNode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="SUGGESTED"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   FontFamily="{DynamicResource BodyFont}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Margin="12,8,0,6"/>
                        <Button Style="{DynamicResource PopoutButton}"
                                Command="{Binding SelectExitNodeCommand}"
                                CommandParameter="{Binding SuggestedNode.Id}"
                                Padding="12,9">
                            <DockPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Button}}"
                                       Margin="0,0,20,0">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="&#xE73E;"
                                           FontFamily="{DynamicResource IconFont}"
                                           FontSize="13"
                                           Foreground="{DynamicResource GreenBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding SuggestedNode.IsSelected, Converter={StaticResource BoolToVis}}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE945;"
                                               FontFamily="{DynamicResource IconFont}"
                                               FontSize="14"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <StackPanel>
                                        <TextBlock FontFamily="{DynamicResource BodyFont}" FontSize="13">
                                            <Run Text="Best available"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 FontWeight="SemiBold"/>
                                        </TextBlock>
                                        <TextBlock FontFamily="{DynamicResource BodyFont}" FontSize="12"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   Margin="0,2,0,0">
                                            <Run Text="{Binding SuggestedNode.City, Mode=OneWay}"/>
                                            <Run Text=","/>
                                            <Run Text="{Binding SuggestedNode.Country, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </Button>
                    </StackPanel>

                    <!-- None option -->
                    <Button Style="{DynamicResource PopoutButton}"
                            Command="{Binding ClearExitNodeCommand}"
                            Padding="12,9">
                        <DockPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Button}}"
                                   Margin="0,0,20,0">
                            <TextBlock DockPanel.Dock="Right"
                                       Text="&#xE73E;"
                                       FontFamily="{DynamicResource IconFont}"
                                       FontSize="13"
                                       Foreground="{DynamicResource GreenBrush}"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedExitNodeId}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="None"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="{DynamicResource BodyFont}"
                                       FontSize="13"/>
                        </DockPanel>
                    </Button>

                    <!-- ── Tailnet exit nodes ── -->
                    <TextBlock Text="YOUR NODES"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="11" FontWeight="SemiBold"
                               Margin="12,10,0,6"
                               Visibility="{Binding TailnetExitNodes.Count, Converter={StaticResource BoolToVis}}"/>

                    <ItemsControl ItemsSource="{Binding TailnetExitNodes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{DynamicResource PopoutButton}"
                                        Command="{Binding DataContext.SelectExitNodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Id}"
                                        Padding="12,8"
                                        Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
                                    <DockPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Button}}"
                                               Margin="0,0,20,0">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="&#xE73E;"
                                                   FontFamily="{DynamicResource IconFont}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource GreenBrush}"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8"
                                                     Fill="{Binding IsOnline, Converter={StaticResource OnlineBrush}}"
                                                     Margin="0,0,10,0"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding HostName}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontFamily="{DynamicResource BodyFont}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ── Location-based exit nodes ── -->
                    <TextBlock Text="EXIT NODES"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               FontFamily="{DynamicResource BodyFont}"
                               FontSize="11" FontWeight="SemiBold"
                               Margin="12,10,0,6"
                               Visibility="{Binding LocationExitNodes.Count, Converter={StaticResource BoolToVis}}"/>

                    <!-- Country groups -->
                    <ItemsControl ItemsSource="{Binding LocationExitNodes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
                                    <Button Style="{DynamicResource PopoutButton}"
                                            Padding="12,9"
                                            Command="{x:Static vm:ExitNodePickerViewModel.ToggleCountryExpandedCommand}"
                                            CommandParameter="{Binding}"
                                            HorizontalContentAlignment="Stretch">
                                        <DockPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Button}}"
                                                   Margin="0,0,20,0">
                                            <!-- Checkmark if any child selected -->
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="&#xE73E;"
                                                       FontFamily="{DynamicResource IconFont}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource GreenBrush}"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}"/>
                                            <!-- Expand chevron -->
                                            <TextBlock DockPanel.Dock="Right"
                                                       FontFamily="{DynamicResource IconFont}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#xE76C;"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Text" Value="&#xE70D;"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal">
                                                <ContentControl Margin="0,0,10,0" VerticalAlignment="Center">
                                                    <ContentControl.Style>
                                                        <Style TargetType="ContentControl">
                                                            <Setter Property="Content" Value="{Binding}"/>
                                                            <Setter Property="ContentTemplate">
                                                                <Setter.Value>
                                                                    <DataTemplate>
                                                                        <Border Background="{DynamicResource SubtleBrush}"
                                                                                CornerRadius="3"
                                                                                Padding="4,2">
                                                                            <TextBlock Text="{Binding CountryCode}"
                                                                                       FontFamily="{DynamicResource BodyFont}"
                                                                                       FontSize="11"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShowFlag}" Value="True">
                                                                    <Setter Property="ContentTemplate">
                                                                        <Setter.Value>
                                                                            <DataTemplate>
                                                                                <emoji:TextBlock Text="{Binding Flag}"
                                                                                                 FontSize="16"/>
                                                                            </DataTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ContentControl.Style>
                                                </ContentControl>
                                                <TextBlock VerticalAlignment="Center"
                                                           FontFamily="{DynamicResource BodyFont}" FontSize="13">
                                                    <Run Text="{Binding Country, Mode=OneWay}"
                                                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <Run Text="·"
                                                         Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                    <Run Text="{Binding CityCount, Mode=OneWay, StringFormat='{}{0} cities'}"
                                                         Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </Button>

                                    <!-- Expanded cities -->
                                    <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                                                Margin="32,0,0,0">
                                        <!-- Best available for country -->
                                        <Button Style="{DynamicResource PopoutButton}"
                                                Padding="12,7"
                                                Visibility="{Binding BestAvailable, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.SelectExitNodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding BestAvailable.Id}">
                                            <TextBlock FontFamily="{DynamicResource BodyFont}" FontSize="13">
                                                <Run Text="&#xE945;"
                                                     FontFamily="{DynamicResource IconFont}"
                                                     FontSize="12"/>
                                                <Run Text=" Best Available"
                                                     Foreground="{DynamicResource AccentBrush}"
                                                     FontWeight="SemiBold"/>
                                            </TextBlock>
                                        </Button>

                                        <!-- City groups -->
                                        <ItemsControl ItemsSource="{Binding Cities}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
                                                        <!-- City row: click picks best relay, chevron expands relays -->
                                                        <DockPanel>
                                                            <!-- Small expand chevron (only if >1 relay) -->
                                                            <Button DockPanel.Dock="Right"
                                                                    Width="28" Height="28"
                                                                    Padding="0"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,6,0"
                                                                    Command="{x:Static vm:ExitNodePickerViewModel.ToggleCityExpandedCommand}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Setter Property="BorderThickness" Value="0"/>
                                                                        <Setter Property="Cursor" Value="Hand"/>
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="Button">
                                                                                    <Border Background="{TemplateBinding Background}"
                                                                                            CornerRadius="4">
                                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter Property="Background" Value="{DynamicResource SubtleBrush}"/>
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding RelayCount}" Value="1">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                                <TextBlock FontFamily="{DynamicResource IconFont}"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="&#xE76C;"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                    <Setter Property="Text" Value="&#xE70D;"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Button>
                                                            <!-- Main city button selects best relay -->
                                                            <Button Style="{DynamicResource PopoutButton}"
                                                                    Padding="12,7"
                                                                    Command="{Binding DataContext.SelectExitNodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding BestId}">
                                                                <DockPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                           Margin="0,0,20,0">
                                                                    <TextBlock DockPanel.Dock="Right"
                                                                               Text="&#xE73E;"
                                                                               FontFamily="{DynamicResource IconFont}"
                                                                               FontSize="13"
                                                                               Foreground="{DynamicResource GreenBrush}"
                                                                               VerticalAlignment="Center"
                                                                               Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}"/>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Ellipse Width="7" Height="7"
                                                                                 Fill="{Binding IsOnline, Converter={StaticResource OnlineBrush}}"
                                                                                 Margin="0,0,10,0"
                                                                                 VerticalAlignment="Center"/>
                                                                        <TextBlock Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                   FontFamily="{DynamicResource BodyFont}"
                                                                                   FontSize="13"
                                                                                   VerticalAlignment="Center">
                                                                            <Run Text="{Binding CityName, Mode=OneWay}"/>
                                                                            <Run Text="{Binding RelayCountLabel, Mode=OneWay}"
                                                                                 Foreground="{DynamicResource TextTertiaryBrush}"
                                                                                 FontSize="12"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </DockPanel>
                                                            </Button>
                                                        </DockPanel>

                                                        <!-- Expanded relay list -->
                                                        <ItemsControl ItemsSource="{Binding Relays}"
                                                                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                                                                      Margin="24,0,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Button Style="{DynamicResource PopoutButton}"
                                                                            Padding="12,6"
                                                                            Command="{Binding DataContext.SelectExitNodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding Id}">
                                                                        <DockPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                                   Margin="0,0,20,0">
                                                                            <TextBlock DockPanel.Dock="Right"
                                                                                       Text="&#xE73E;"
                                                                                       FontFamily="{DynamicResource IconFont}"
                                                                                       FontSize="12"
                                                                                       Foreground="{DynamicResource GreenBrush}"
                                                                                       VerticalAlignment="Center"
                                                                                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}"/>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Ellipse Width="6" Height="6"
                                                                                         Fill="{Binding IsOnline, Converter={StaticResource OnlineBrush}}"
                                                                                         Margin="0,0,8,0"
                                                                                         VerticalAlignment="Center"/>
                                                                                <TextBlock Text="{Binding HostName}"
                                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                           FontFamily="{DynamicResource BodyFont}"
                                                                                           FontSize="12"
                                                                                           VerticalAlignment="Center"/>
                                                                            </StackPanel>
                                                                        </DockPanel>
                                                                    </Button>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
